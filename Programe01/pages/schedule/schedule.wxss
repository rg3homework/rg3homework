.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
/* 箭头按钮容器 */
.arrow-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
}
/* 箭头图标大小 */
.arrow-icon {
  width: 30rpx;
  height: 30rpx;
}

.calendar-week, .calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
}
.calendar-week text {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}
.day-item {
  position: relative;
  padding: 15rpx 0;
  font-size: 28rpx;
}
.day-item.active {
  background: #4285F4;
  color: #fff;
  border-radius: 50%;
}
.dot {
  position: absolute;
  bottom: 5rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  background: #4285F4;
  border-radius: 50%;
}

/* 日程列表容器 */
.schedule-list {
  margin-top: 20rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

/* 无日程：居中框 */
.schedule-empty-box {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 60rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.empty-tip {
  font-size: 26rpx;
  color: #999;
}

/* 有日程：居左列表框 */
.schedule-content-box {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
}
.schedule-item {
  font-size: 26rpx;
  color: #333;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #eee;
}
.schedule-item:last-child {
  border-bottom: none;
}

.new-btn {
  margin-top: 30rpx;
  width: 100%;
}