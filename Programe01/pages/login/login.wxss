.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 40rpx 0;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 居中图标+标题 */
.logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}
.logo-img {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

/* 勾选协议样式 */
.checkbox-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 60rpx;
  width: 100%;
  justify-content: center;
}
.checkbox {
  margin-right: 15rpx;
  transform: scale(0.8);
}
.tips-text {
  font-size: 26rpx;
  color: #666;
}

/* 登录按钮 */
.login-btn {
  width: 600rpx;
  font-size: 32rpx;
  background: #4285F4;
  color: #fff;
}
.login-btn.disabled {
  background: #ccc;
  color: #999;
}