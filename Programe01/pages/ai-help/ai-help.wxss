.container {

  padding: 40rpx;

}


.title {

  font-size: 42rpx;

  font-weight: bold;

  margin-bottom: 40rpx;

}


.input {

  border: 1px solid #ccc;

  border-radius: 12rpx;

  padding: 20rpx;

  background: #fff;

}


.btn {

  margin-top: 30rpx;

  background: #4CAF50;

  color: white;

}


.reply-box {

  margin-top: 40rpx;

  padding: 30rpx;

  background: #f5f5f5;

  border-radius: 16rpx;

}


.reply-title {

  font-weight: bold;

  margin-bottom: 20rpx;

}


.reply-content {

  line-height: 1.7;

}