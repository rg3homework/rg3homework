.card-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.empty-box {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 60rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.empty-tip {
  font-size: 26rpx;
  color: #999;
}
.content-box {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
}
.record-item {
  font-size: 26rpx;
  color: #333;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #eee;
}
.record-item:last-child {
  border-bottom: none;
}