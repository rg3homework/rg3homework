.card-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.empty-box {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 60rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.empty-tip {
  font-size: 26rpx;
  color: #999;
}
.content-box {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
}
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}
.record-item:last-child {
  border-bottom: none;
}
.record-info .record-name {
  display: block;
  font-size: 28rpx;
}
.record-info .record-date {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 5rpx;
}
.record-amount {
  font-size: 30rpx;
  font-weight: bold;
  color: #ff4d4f;
}