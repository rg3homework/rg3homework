<view class="container">
  <!-- 1. 问候&天气 -->
  <view class="greeting">
    <text class="greet-text">{{greetText}}！</text>
    <text class="weather-text">今天是{{weatherData.text}}的一天</text>
  </view>

  <!-- 2. 状态卡片区（加上图标） -->
  <view class="status-cards">
    <view class="card status-card">
      <view class="status-item">
        <image src="/images/temperature.png" class="status-icon"></image>
        <text class="label">今日温度</text>
        <text class="value">{{weatherData.temp}}℃</text>
      </view>
      <view class="status-item">
        <image src="/images/weather.png" class="status-icon"></image>
        <text class="label">今日天气</text>
        <text class="value">{{weatherData.text}}</text>
      </view>
      <view class="status-item">
        <image src="/images/clean.png" class="status-icon"></image>
        <text class="label">今日值日</text>
        <text class="value">{{todayDuty || '无安排'}}</text>
      </view>
    </view>
  </view>

  <!-- 3. 功能快捷入口（加上图标） -->
  <view class="func-cards">
    <view class="card func-card">
      <view class="func-grid">
        <view class="func-item" bindtap="goToWeather">
          <image src="/images/weather_remind.png" class="func-icon"></image>
          <text>天气提醒</text>
        </view>
        <view class="func-item" bindtap="showLateRemind">
          <image src="/images/late_remind.png" class="func-icon"></image>
          <text>晚归提醒</text>
        </view>
        <view class="func-item" bindtap="goToRule">
          <image src="/images/rule.png" class="func-icon"></image>
          <text>寝室公约</text>
        </view>
        <view class="func-item" bindtap="goToAiHelp">
          <image src="/images/mediation.png" class="func-icon"></image>
          <text>矛盾调解</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 4. 今日提醒区 -->
  <view class="remind-area">
    <view class="card remind-card">
      <view class="card-title">今日提醒</view>
      <!-- 无待办：居中框 -->
      <view 
        wx:if="{{todayReminds.length === 0}}" 
        class="remind-empty-box"
      >
        <text class="empty-tip">暂无待办事项~</text>
      </view>
      <!-- 有待办：列表显示 -->
      <view wx:else class="remind-content-box">
        <view wx:for="{{todayReminds}}" wx:key="index" class="remind-item">
          <text>{{item.content}}</text>
        </view>
      </view>
    </view>
  </view>
</view>