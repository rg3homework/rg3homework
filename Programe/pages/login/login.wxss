.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.logo {
  text-align: center;
  margin-bottom: 150rpx;
}
.logo image {
  width: 160rpx;
  height: 160rpx;
}
.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-top: 20rpx;
}
.login-btn {
  width: 600rpx;
  font-size: 32rpx;
}
.tips {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}