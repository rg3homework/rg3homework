<view class="container login-page">
  <view class="logo">
    <image src="/images/logo.png" mode="aspectFit"></image>
    <text class="title">宿居管家</text>
  </view>

  <view class="login-btn-wrap">
    <button class="btn login-btn" open-type="getUserInfo" bindgetuserinfo="handleGetUserInfo">
      微信一键登录
    </button>
  </view>

  <view class="tips">
    登录即代表同意《用户协议》和《隐私政策》
  </view>
</view>