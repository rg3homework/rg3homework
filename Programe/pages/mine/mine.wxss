.user-info {
  display: flex;
  align-items: center;
}
.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 30rpx;
}
.info .nickname {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
}
.info .dorm {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-top: 10rpx;
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #eee;
}
.menu-item:last-child {
  border-bottom: none;
}
.arrow {
  color: #999;
}
.logout-text {
  color: #ff4d4f;
}